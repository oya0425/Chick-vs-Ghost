struct pixcelIn
{
	float4 pos : SV_POSITION;
	float2 tx0 : TEXCOORD0;
    float4 col : COLOR0;
};

Texture2D txDiffuse : register( t0 );
SamplerState samLinear : register( s0 );

float4 main(pixcelIn IN) : SV_Target
{
	//テクスチャのサンプリング
	float4 color = txDiffuse.Sample(samLinear, IN.tx0)*IN.col;

	return color;
}
